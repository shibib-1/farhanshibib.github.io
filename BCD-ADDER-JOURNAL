<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BCD Adder — Lab Journal</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #0a0e13;
    --surface: #111820;
    --surface2: #162030;
    --border: #1e3048;
    --accent: #00c2ff;
    --accent2: #00ff9d;
    --warn: #ff6b35;
    --text: #cdd9e5;
    --text-dim: #6b8299;
    --mono: 'Share Tech Mono', monospace;
    --sans: 'Outfit', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,194,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,194,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 60px 24px 120px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  header {
    margin-bottom: 64px;
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    animation: fadeUp 0.6s ease both;
  }

  .breadcrumb {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
  }

  .breadcrumb span { color: var(--accent); }

  h1 {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 12px;
  }

  h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .meta {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  .meta-item {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .meta-item::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent2);
    display: block;
  }

  /* Tags */
  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 20px;
  }

  .tag {
    font-family: var(--mono);
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-dim);
    background: var(--surface);
    letter-spacing: 0.05em;
  }

  /* Section */
  section {
    margin-bottom: 56px;
    animation: fadeUp 0.6s ease both;
  }

  section:nth-child(2) { animation-delay: 0.1s; }
  section:nth-child(3) { animation-delay: 0.2s; }
  section:nth-child(4) { animation-delay: 0.3s; }

  .section-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  h2 {
    font-size: 22px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  p {
    color: var(--text);
    margin-bottom: 16px;
    font-size: 15px;
  }

  /* What I built — component cards */
  .component-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    margin-top: 24px;
  }

  .component-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .component-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .component-name {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--accent);
    margin-bottom: 6px;
  }

  .component-desc {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* Signal flow diagram */
  .signal-flow {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 28px 0;
    overflow-x: auto;
    padding: 20px 0;
  }

  .flow-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 10px 14px;
    text-align: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .flow-block .fb-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    display: block;
  }

  .flow-block .fb-name {
    font-size: 12px;
    color: var(--text-dim);
    display: block;
    margin-top: 2px;
  }

  .flow-arrow {
    color: var(--accent);
    font-family: var(--mono);
    font-size: 18px;
    padding: 0 6px;
    flex-shrink: 0;
  }

  /* Problems — accordion style */
  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .problem-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .problem-item:hover { border-color: var(--border); }

  .problem-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 20px;
    cursor: pointer;
    user-select: none;
  }

  .problem-header:hover .problem-title { color: var(--accent); }

  .problem-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    background: rgba(0,194,255,0.08);
    border: 1px solid rgba(0,194,255,0.2);
    padding: 3px 8px;
    border-radius: 2px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .problem-title {
    font-size: 15px;
    font-weight: 600;
    color: #fff;
    transition: color 0.2s;
    flex: 1;
  }

  .problem-severity {
    font-family: var(--mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .sev-high { background: rgba(255,107,53,0.1); color: var(--warn); border: 1px solid rgba(255,107,53,0.2); }
  .sev-med  { background: rgba(255,193,7,0.1);  color: #ffc107;     border: 1px solid rgba(255,193,7,0.2); }
  .sev-low  { background: rgba(0,255,157,0.1);  color: var(--accent2); border: 1px solid rgba(0,255,157,0.2); }

  .problem-body {
    padding: 0 20px 18px 52px;
  }

  .problem-body p {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 10px;
  }

  .fix-box {
    background: rgba(0,255,157,0.04);
    border: 1px solid rgba(0,255,157,0.15);
    border-radius: 3px;
    padding: 12px 16px;
    margin-top: 10px;
  }

  .fix-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--accent2);
    letter-spacing: 0.1em;
    margin-bottom: 6px;
  }

  .fix-box p {
    font-size: 13px;
    color: var(--text);
    margin: 0;
  }

  /* Voltage readings inline code */
  code {
    font-family: var(--mono);
    font-size: 12px;
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 2px 6px;
    border-radius: 2px;
    color: var(--accent);
  }

  /* Lessons learned */
  .lessons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    margin-top: 8px;
  }

  .lesson-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  }

  .lesson-card:hover {
    transform: translateY(-2px);
    border-color: var(--accent2);
  }

  .lesson-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent2), transparent);
  }

  .lesson-icon {
    font-size: 24px;
    margin-bottom: 12px;
    display: block;
  }

  .lesson-title {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
  }

  .lesson-body {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.6;
    margin: 0;
  }

  /* Footer */
  footer {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: gap;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    animation: fadeUp 0.6s 0.4s ease both;
  }

  .status-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent2);
    margin-right: 8px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
